	<script>
	document.addEventListener('DOMContentLoaded', function() {
		const observer = new MutationObserver(() => {
			const title = document.querySelector('h3.ct-module-title');
			if (title && title.textContent.includes('Vous aimerez peut-être aussi')) {
				title.textContent = 'Suggestions de lecture';
				observer.disconnect();
			}
		});

		observer.observe(document.body, {
			childList: true,
			subtree: true
		});
	});
	</script>
	
